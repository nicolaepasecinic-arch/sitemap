# Copy to .env for local dev. In Coolify, set these as Environment Variables.
DATABASE_URL=postgres://qoders:qoders@localhost:5432/qoders
JWT_SECRET=change-me-to-a-long-random-string
CORS_ORIGIN=http://localhost:3000
# Backend runs on 4000 locally so it doesn't clash with the React dev server (3000).
PORT=4000
# Set to true only if your Postgres requires SSL
PGSSL=false

# Firecrawl — site crawler/scraper (https://firecrawl.dev)
FIRECRAWL_API_KEY=

# OpenAI — powers the AI "Generate content map" button (https://platform.openai.com)
OPENAI_API_KEY=
# Optional: override the model (defaults to gpt-5.4). e.g. gpt-5.5, gpt-5.5-pro
OPENAI_MODEL=gpt-5.4
