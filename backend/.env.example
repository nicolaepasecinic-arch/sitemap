# ============================================================================
#  Qoders backend — environment variables
#  Copy this file to `.env` for local dev. In production (Coolify) set the same
#  keys as Environment Variables on the application.
# ============================================================================

# --- Database (required) --------------------------------------------------
# Postgres connection string. Locally this points at the docker-compose db or a
# local Postgres. In Coolify use the INTERNAL connection string of the Postgres
# resource (host = the service name, NOT localhost).
DATABASE_URL=postgres://qoders:qoders@localhost:5432/qoders
# Set to "true" only if your Postgres requires SSL (most managed DBs do; a
# Coolify-hosted Postgres on the same network does NOT — keep false).
PGSSL=false

# --- Auth (required) ------------------------------------------------------
# Secret used to sign login tokens (JWT). Use a long random string.
JWT_SECRET=change-me-to-a-long-random-string

# --- URLs / server (required) ---------------------------------------------
# Public URL of the app. Used for share links and (in production) baked into the
# frontend so it knows where the API lives. e.g. https://design.upqode.com
APP_URL=http://localhost:3000
# Which origin is allowed to call the API (CORS). Usually the same as APP_URL.
CORS_ORIGIN=http://localhost:3000
# Port the backend listens on. Locally 4000 avoids clashing with the React dev
# server (3000). In the production container it's 3000 (see docker-compose.coolify.yml).
PORT=4000

# --- OpenAI (required for AI features) ------------------------------------
# https://platform.openai.com — powers AI sitemap + style-guide generation.
OPENAI_API_KEY=
# Main model (defaults to gpt-5.4 if unset).
OPENAI_MODEL=gpt-5.4
# Cheap model for tiny lookups (e.g. "closest Google Font" for a proprietary font).
OPENAI_CHEAP_MODEL=gpt-5.4-mini

# --- ScreenshotEngine (recommended) ---------------------------------------
# https://screenshotengine.com — renders a site to an image so the AI can read a
# brand's look when the headless probe isn't available. Used as a fallback.
SCREENSHOTENGINE_API_KEY=

# --- Firecrawl (optional) -------------------------------------------------
# https://firecrawl.dev — used by the Crawler tab (mapping site URLs) and as an
# optional fallback for reading a site's computed styles. Can be left blank.
FIRECRAWL_API_KEY=

# --- Email (optional) -----------------------------------------------------
# https://resend.com — sends share-invite emails. Leave blank to disable email.
RESEND_API_KEY=
MAIL_FROM=
