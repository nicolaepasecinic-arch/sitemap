# ============================================================================
#  Qoders frontend — environment (Create React App)
#  Copy to `.env.local` for local dev.
# ============================================================================

# Base URL of the backend API. Baked in at BUILD time (CRA).
#   - empty   → the app uses localStorage only (offline / no backend)
#   - set     → the app calls this URL for /api/...
#
# Local dev:   REACT_APP_API_URL=http://localhost:4000
# Production:  set automatically from APP_URL by docker-compose.coolify.yml,
#              e.g. https://design.upqode.com  (nginx then proxies /api → backend)
REACT_APP_API_URL=
